        <activity
            android:name=".PartitionActivity"
            android:exported="false" />

        <activity
            android:name=".AiAssistantActivity"
            android:exported="false" />

        <activity
            android:name=".ThemePickerActivity"
            android:exported="false" />

        <activity
            android:name=".ApkExtractActivity"
            android:exported="false" />
        <activity
            android:name=".CustomCleanActivity"
            android:exported="false" />
        <activity
            android:name=".CustomRuleEditActivity"
            android:exported="false" />
        <activity
            android:name=".MemoryBoostActivity"
