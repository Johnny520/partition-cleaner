<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="?attr/colorOnPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/custom_field_name"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/custom_field_name_hint"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/custom_field_roots"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <EditText
                android:id="@+id/et_roots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/custom_field_roots_hint"
                android:inputType="textMultiLine"
                android:minLines="2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/custom_field_mode"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <Spinner
                android:id="@+id/sp_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tv_patterns_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/custom_field_patterns"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <EditText
                android:id="@+id/et_patterns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/custom_field_patterns_hint"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/custom_field_minsize"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <EditText
                android:id="@+id/et_minsize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/custom_field_advice"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <Spinner
                android:id="@+id/sp_advice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/custom_field_reason"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <EditText
                android:id="@+id/et_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/custom_field_reason_hint"
                android:inputType="text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/custom_save" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
